# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing — never commit these
**/key.properties
*.jks
*.keystore

# Backend (Python / FastAPI)
backend/.venv/
backend/.env
backend/*.db
backend/*.db-journal
backend/*.db-wal
backend/*.db-shm
backend/.ruff_cache/
backend/data/
**/__pycache__/
