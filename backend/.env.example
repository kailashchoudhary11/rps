# SQLite database file (path is relative to where uvicorn runs)
DATABASE_URL=sqlite:///./pic_studios.db

# R2 / S3-compatible storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pic-studios
# Leave blank to derive from R2_ACCOUNT_ID; override if you use a custom S3 endpoint
R2_ENDPOINT_URL=

# How long presigned URLs stay valid (seconds)
PRESIGNED_URL_TTL=3600

# Comma-separated CORS allow-list; "*" for development
CORS_ORIGINS=*
